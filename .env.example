# =========================
# Slack Incoming Webhook
# =========================
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/XXX/YYY/ZZZ"
SLACK_USERNAME="YK Web Watchdog"
SLACK_ICON_EMOJI=":dog:"
SLACK_POST_MODE="json"          # json or payload
ALWAYS_MENTION="<@UXXXXXXXX>"   # optional user/channel mention
CHANNEL_MENTION_ON_FAIL="1"
ENABLE_MENTIONS="0"

# =========================
# Targets
# =========================
TARGETS="https://example.com/"

# =========================
# Timeout / Slow threshold
# =========================
HC_TIMEOUT_SEC="10"
HC_SLOW_MS="1500"

# =========================
# Reporting / Daily Report
# =========================
REPORT_MODE="on_error"            # always, on_change, on_error
STATE_FILE="/home/$USER/Workspace/yk-web-watchdog/state.json"
DAILY_REPORT_TIME="09:00"
DAILY_REPORT_ENABLED="1"

HEADER_KEYS="strict-transport-security,cache-control,etag,last-modified,server,content-type,date,cf-cache-status,cf-ray,x-cache,via"

# =========================
# Certificate expiry alerting
# =========================
CERT_WARN_DAYS="30"
CERT_ALERT_DAYS="7"
CERT_MAX_SAN_ITEMS="15"

# =========================
# Redirect chain tracing
# =========================
MAX_REDIRECTS="10"

# =========================
# Logging
# =========================
LOG_DIR="/home/$USER/Workspace/yk-web-watchdog/logs"
SLACK_MAX_CHARS="8000"

# =========================
# Enhanced Features
# =========================
SLACK_IMAGE_URL=""
SLACK_EMOJI_ROTATION="1"
